<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <springProperty scope="context" name="appName"
                    source="spring.application.name"
                    defaultValue="vector-test-app"/>

    <!-- ================================================================
         [1] app.log  –  애플리케이션 비즈니스 로그 (INFO+)
         current : /data/logs/current/app.log
         archive : /data/logs/archive/yyyy/MM/dd/app.log.gz  (자동 압축)
         ================================================================ -->
    <appender name="FILE_APP" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>/data/logs/current/app.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- .gz 확장자 → 로테이션 시 자동 gzip 압축 -->
            <fileNamePattern>/data/logs/archive/%d{yyyy/MM/dd}/app.log.gz</fileNamePattern>
            <maxHistory>1</maxHistory>        <!-- 1일치 보관 -->
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSS'Z'</timestampPattern>
            <timeZone>UTC</timeZone>
            <customFields>{"app":"${appName}","log_type":"app"}</customFields>
        </encoder>
    </appender>

    <!-- ================================================================
         [2] error.log  –  ERROR 레벨 전용
         current : /data/logs/current/error.log
         archive : /data/logs/archive/yyyy/MM/dd/error.log.gz
         ================================================================ -->
    <appender name="FILE_ERROR" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>/data/logs/current/error.log</file>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>/data/logs/archive/%d{yyyy/MM/dd}/error.log.gz</fileNamePattern>
            <maxHistory>1</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSS'Z'</timestampPattern>
            <timeZone>UTC</timeZone>
            <customFields>{"app":"${appName}","log_type":"error"}</customFields>
        </encoder>
    </appender>

    <!-- 개발 시 콘솔 확인용 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="FILE_APP"/>
        <appender-ref ref="FILE_ERROR"/>
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>
